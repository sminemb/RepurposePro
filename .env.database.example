# Docker Compose bootstrap
POSTGRES_USER=repurposepro
POSTGRES_PASSWORD=repurposepro_local
POSTGRES_DB=repurposepro
POSTGRES_OWNER_PASSWORD=repurposepro_owner_local
POSTGRES_RUNTIME_PASSWORD=repurposepro_runtime_local

# Database administration. Never load this file into API, worker, auth, or web processes.
DATABASE_BOOTSTRAP_URL=postgresql://repurposepro:repurposepro_local@localhost:5432/repurposepro
DATABASE_MIGRATION_URL=postgresql://repurposepro_owner:repurposepro_owner_local@localhost:5432/repurposepro
DATABASE_RUNTIME_URL=postgresql://repurposepro_runtime:repurposepro_runtime_local@localhost:5432/repurposepro

# Disposable PostgreSQL billing integration databases
TEST_DATABASE_BOOTSTRAP_URL=postgresql://repurposepro:repurposepro_local@localhost:5432/repurposepro
TEST_DATABASE_MIGRATION_URL=postgresql://repurposepro_owner:repurposepro_owner_local@localhost:5432/repurposepro
TEST_DATABASE_RUNTIME_URL=postgresql://repurposepro_runtime:repurposepro_runtime_local@localhost:5432/repurposepro
