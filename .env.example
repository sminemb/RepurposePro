# Runtime
NODE_ENV=development
APP_ENV=local
APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
API_PORT=4000

# Better Auth
BETTER_AUTH_SECRET=replace-with-a-long-random-development-secret
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3000

# PostgreSQL
POSTGRES_USER=repurposepro
POSTGRES_PASSWORD=repurposepro_local
POSTGRES_DB=repurposepro
DATABASE_URL=postgresql://repurposepro:repurposepro_local@localhost:5432/repurposepro
DATABASE_POOL_MAX=10
DATABASE_SSL=false

# Redis
REDIS_URL=redis://localhost:6379

# Logging
LOG_LEVEL=debug
LOG_PRETTY=true
