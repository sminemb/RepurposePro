# Runtime
NODE_ENV=development
APP_ENV=local
APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
API_PORT=4000

# Better Auth
BETTER_AUTH_SECRET=replace-with-a-long-random-development-secret
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3000

# PostgreSQL runtime only. Administrative credentials belong in .env.database.
DATABASE_URL=postgresql://repurposepro_runtime:repurposepro_runtime_local@localhost:5432/repurposepro
DATABASE_POOL_MAX=10
DATABASE_SSL=false

# Redis
REDIS_URL=redis://localhost:6379
BULLMQ_PREFIX=repurposepro

# Storage
STORAGE_DRIVER=local
STORAGE_ROOT=./storage
FILE_RETENTION_DAYS=7
MAX_UPLOAD_BYTES=524288000
MAX_VIDEO_DURATION_SECONDS=1800

# Video probing
FFPROBE_PATH=ffprobe

# Stripe Checkout (test mode) — paste real dashboard values before starting the API.
STRIPE_SECRET_KEY=
STRIPE_STARTER_PRICE_ID=
STRIPE_CREATOR_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_SUCCESS_URL=http://localhost:3000/billing?checkout=success
STRIPE_CANCEL_URL=http://localhost:3000/billing?checkout=cancelled
# Needed when VS3-T4 webhook verification is enabled.
STRIPE_WEBHOOK_SECRET=

# Arcjet Checkout protection (test mode) — paste the real key before starting the API.
ARCJET_KEY=
ARCJET_MODE=DRY_RUN

# Logging
LOG_LEVEL=debug
LOG_PRETTY=true
