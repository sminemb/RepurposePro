# Runtime
NODE_ENV=development
APP_ENV=local
APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
API_PORT=4000

# Better Auth
BETTER_AUTH_SECRET=replace-with-a-long-random-development-secret
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3000

# PostgreSQL
POSTGRES_USER=repurposepro
POSTGRES_PASSWORD=repurposepro_local
POSTGRES_DB=repurposepro
POSTGRES_OWNER_PASSWORD=repurposepro_owner_local
POSTGRES_RUNTIME_PASSWORD=repurposepro_runtime_local
DATABASE_URL=postgresql://repurposepro_runtime:repurposepro_runtime_local@localhost:5432/repurposepro
DATABASE_MIGRATION_URL=postgresql://repurposepro_owner:repurposepro_owner_local@localhost:5432/repurposepro
# Existing database upgrade only; do not use for runtime application connections.
DATABASE_BOOTSTRAP_URL=
DATABASE_POOL_MAX=10
DATABASE_SSL=false

# Redis
REDIS_URL=redis://localhost:6379

# Storage
STORAGE_DRIVER=local
STORAGE_ROOT=./storage
FILE_RETENTION_DAYS=7
MAX_UPLOAD_BYTES=524288000
MAX_VIDEO_DURATION_SECONDS=1800

# Video probing
FFPROBE_PATH=ffprobe

# Logging
LOG_LEVEL=debug
LOG_PRETTY=true
